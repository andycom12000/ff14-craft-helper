{
  "name": "ff14-craft-helper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-tesseract-worker.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-tesseract-worker.mjs",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "type-check": "vue-tsc -b",
    "build-game-data": "node scripts/build-game-data.mjs",
    "patch-wasm": "node scripts/patch-wasm-rayon-init.mjs",
    "sync-tesseract": "node scripts/sync-tesseract-worker.mjs",
    "bench:solver": "node scripts/dev/bench-solver.mjs --dataset=dataset-3 --csv",
    "bench:solver:single": "node scripts/dev/bench-solver.mjs --dataset=dataset-3 --threads=1",
    "ga:analyze": "node scripts/dev/ga-analyze.mjs"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "d3": "^7.9.0",
    "element-plus": "^2.9.0",
    "pinia": "^3.0.0",
    "pinia-plugin-persistedstate": "^4.2.0",
    "tesseract.js": "^7.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google-analytics/data": "^6.0.0",
    "@types/d3": "^7.4.3",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "csv-parse": "^5.5.6",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "happy-dom": "^20.8.3",
    "puppeteer-core": "^24.38.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.59.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.0"
  }
}
